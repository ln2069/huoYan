# 运行环境
#   mock   - 使用本地模拟数据（默认，开发阶段）
#   real   - 请求真实后端接口
VITE_REPO_TYPE=mock

# 后端接口基础地址（当 VITE_REPO_TYPE=real 时生效）
VITE_API_BASE_URL=http://localhost:8080/api

# 认证 Token（登录后由后端颁发）
# VITE_AUTH_TOKEN=

# HTTP Basic Auth 凭据（对接后端统一密码保护）
VITE_AUTH_USERNAME=admin
VITE_AUTH_PASSWORD=change-this-password

# 环境标识
VITE_APP_ENV=development

